async def scrapper_instagram():
    """Fase 1: Extracción forzada de 10 publicaciones x 15 comentarios cada una"""
    print(f"[*] Iniciando extracción profunda de @{TARGET_USER}...")
    dataset = {"usuario": TARGET_USER, "posts": []}

    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True)
        context = await browser.new_context(viewport={'width': 1280, 'height': 1080})
        
        await context.add_cookies([{
            "name": "sessionid", 
            "value": SESSION_ID, 
            "domain": ".instagram.com", 
            "path": "/"
        }])
        
        page = await context.new_page()

        try:
            # 1. CARGA DEL PERFIL CON SCROLL DINÁMICO
            await page.goto(f"https://www.instagram.com/{TARGET_USER}/", timeout=60000)
            await page.wait_for_timeout(5000)
            
            print("[*] Localizando 10 publicaciones en la cuadrícula...")
            enlaces_encontrados = []
            for _ in range(6): 
                hrefs = await page.locator('a[href*="/p/"]').evaluate_all('elements => elements.map(e => e.href)')
                for h in hrefs:
                    if h not in enlaces_encontrados:
                        enlaces_encontrados.append(h)
                if len(enlaces_encontrados) >= 10: break
                await page.mouse.wheel(0, 1200)
                await page.wait_for_timeout(2000)

            urls = enlaces_encontrados[:10]
            print(f"[!] Total de posts a procesar: {len(urls)}")

            # 2. EXTRACCIÓN DETALLADA POR CADA POST
            for idx, url in enumerate(urls):
                print(f"    [+] Entrando a Publicación {idx+1}/10...")
                await page.goto(url, timeout=60000)
                
                # Scroll interno para activar carga de comentarios
                for _ in range(3):
                    await page.mouse.wheel(0, 900)
                    await page.wait_for_timeout(2000)

                try:
                    # Capturamos el cuerpo principal para procesar el texto
                    texto_raw = await page.locator('body').inner_text(timeout=8000)
                except:
                    texto_raw = ""

                lineas = [l.strip() for l in texto_raw.split('\n') if len(l.strip()) > 1]
                
                # Lista de ruido para limpiar el dataset
                ruido = ["Me gusta", "Responder", "Ver traducción", "Compartir", "Guardar", "Seguir", "Follow", "Reply", "Likes"]
                
                comentarios = [
                    l for l in lineas 
                    if l != TARGET_USER and not any(word in l for word in ruido) and not re.match(r'^\d+[smhdw]$', l)
                ]
                
                # Remover descripción del post (autor)
                if comentarios: comentarios.pop(0)
                
                dataset["posts"].append({
                    "id_post": idx + 1,
                    "url": url,
                    "comentarios": comentarios[:15]
                })
                print(f"        ✓ {len(comentarios[:15])} comentarios registrados.")

        except Exception as e:
            print(f"[!] Error en Scraping: {e}")
        finally:
            await browser.close()
            
    return dataset

async def analizar_con_api_flash(datos_json):
    """Fase 2: Procesamiento con Gemini 1.5 Flash (Solución al Error 404)"""
    print(f"\n[☁️] Conectando con la infraestructura de Gemini para análisis semántico...")
    
    prompt = f"""
    Actúa como un experto en análisis de datos y ciberpsicología. 
    Analiza este dataset estructurado en JSON de Instagram:
    
    {json.dumps(datos_json, indent=2)}
    
    Genera un informe académico profesional en TERCERA PERSONA que cubra:
    1. Resumen de actividad y narrativa del perfil.
    2. Perfil conductual basado en las interacciones.
    3. Evaluación de la autenticidad de la comunidad.
    4. Conclusión de reputación digital.
    """
    
    # Probamos las variaciones de nombre de modelo para evitar el error 404
    modelos_a_probar = ["gemini-1.5-flash", "models/gemini-1.5-flash"]
    
    for modelo in modelos_a_probar:
        try:
            response = client.models.generate_content(
                model=modelo,
                contents=prompt
            )
            return response.text
        except Exception as e:
            if "not found" in str(e).lower() or "404" in str(e):
                continue # Prueba el siguiente nombre en la lista
            raise e
    raise Exception("No se pudo conectar con el modelo Gemini 1.5 Flash en ninguna de sus rutas.")

