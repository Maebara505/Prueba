async def scrapper_instagram():
    """Fase 1: Extracción de 10 publicaciones x 15 comentarios"""
    print(f"[*] Iniciando extracción profunda de @{TARGET_USER}...")
    dataset = {"usuario": TARGET_USER, "posts": []}

    async with async_playwright() as p:
        browser = await p.chromium.launch(headless=True)
        context = await browser.new_context()
        
        # Inyectar sesión
        await context.add_cookies([{
            "name": "sessionid", 
            "value": SESSION_ID, 
            "domain": ".instagram.com", 
            "path": "/"
        }])
        
        page = await context.new_page()

        try:
            # Ir al perfil
            await page.goto(f"https://www.instagram.com/{TARGET_USER}/", timeout=60000)
            await page.wait_for_timeout(5000)
            
            # Recolectar URLs de 10 posts
            urls = await page.locator('a[href*="/p/"]').evaluate_all('elements => elements.map(e => e.href)')
            urls = urls[:10]

            for idx, url in enumerate(urls):
                print(f"    [+] Procesando Post {idx+1}/10... (Extrayendo comentarios)")
                await page.goto(url, timeout=60000)
                
                # Scroll para cargar comentarios ocultos
                await page.mouse.wheel(0, 1500)
                await page.wait_for_timeout(5000)

                # Captura de texto del post
                try:
                    bloque_texto = await page.locator('article').inner_text(timeout=5000)
                except:
                    bloque_texto = await page.locator('main').inner_text()

                lineas = [l.strip() for l in bloque_texto.split('\n') if len(l.strip()) > 1]
                
                # Filtrado de ruido de interfaz
                stop_words = ["Me gusta", "Responder", "Ver traducción", "Compartir", "Guardar", "Seguir", "Follow", "Reply"]
                comentarios_limpios = [
                    l for l in lineas 
                    if l != TARGET_USER and not any(word in l for word in stop_words) and not re.match(r'^\d+[smhdw]$', l)
                ]
                
                # Eliminamos el primer elemento (suele ser la descripción del autor)
                if comentarios_limpios: comentarios_limpios.pop(0)
                
                dataset["posts"].append({
                    "id": idx + 1,
                    "enlace": url,
                    "comentarios": comentarios_limpios[:15]
                })

        except Exception as e:
            print(f"[!] Error durante el scraping: {e}")
        finally:
            await browser.close()
            
    return dataset

async def analizar_con_api_flash(datos_json):
    """Fase 2: Conexión con Gemini 1.5 Flash para análisis semántico"""
    print(f"\n[☁️] Conectando con {MODELO_ID} para procesamiento de datos...")
    
    prompt = f"""
    Eres un experto en análisis de datos y ciberpsicología. 
    Analiza el siguiente dataset en JSON extraído de Instagram:
    
    {json.dumps(datos_json, indent=2)}
    
    Genera un informe académico y profesional en TERCERA PERSONA que cubra:
    1. Resumen de la actividad digital y narrativa visual detectada.
    2. Análisis conductual basado en el tono de los comentarios de los seguidores.
    3. Evaluación de la autenticidad de la red social (¿interacciones reales o bots?).
    4. Conclusión sobre los intereses y reputación del perfil analizado.
    """
    
    # Llamada oficial a la librería google-genai
    response = client.models.generate_content(
        model=MODELO_ID,
        contents=prompt
    )
    
    return response.text

async def ejecutar_sistema_completo():
    """Coordinador del flujo"""
    tiempo_inicio = datetime.now()
    
    # 1. Scraping
    data_final = await scrapper_instagram()
    
    if not data_final["posts"]:
        print("[!] No se pudieron recolectar datos. Revisa el SESSION_ID.")
        return

    # 2. IA Análisis
    try:
        informe_final = await analizar_con_api_flash(data_final)
        
        # 3. Guardar JSON y mostrar reporte
        nombre_json = f"analisis_{TARGET_USER}.json"
        with open(nombre_json, "w", encoding="utf-8") as f:
            json.dump(data_final, f, indent=4, ensure_ascii=False)
            
        print("\n" + "="*70)
        print(f"AUDITORÍA ESTRATÉGICA - MODELO {MODELO_ID.upper()}")
        print("="*70)
        print(informe_final)
        print("="*70)
        print(f"Archivo generado: {nombre_json}")
        print(f"Duración: {datetime.now() - tiempo_inicio}")

    except Exception as e:
        print(f"\n[!] Error en la fase de IA: {e}")

# LANZAMIENTO EN COLAB
await ejecutar_sistema_completo()
